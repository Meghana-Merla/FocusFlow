<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="28dp"
    android:background="#0B1020">

    <Space
        android:layout_width="wrap_content"
        android:layout_height="80dp"/>

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Late Night 🌌"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#F5F5F5"/>

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25:00"
        android:textSize="72sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="36dp"/>

    <TextView
        android:id="@+id/tvSessionType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Focus Session"
        android:textSize="18sp"
        android:textColor="#B8C1EC"
        android:layout_marginTop="4dp"/>

    <Spinner
        android:id="@+id/spinnerTime"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="#FFFFFF"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="42dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="▶ Start"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7C4DFF"/>

        <Button
            android:id="@+id/btnPause"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="⏸ Pause"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4A4A4A"
            android:layout_marginStart="14dp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnReset"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="↺ Reset"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#252D47"
        android:layout_marginTop="18dp"/>

    <TextView
        android:id="@+id/tvSessions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sessions Completed: 0"
        android:textSize="18sp"
        android:textColor="#D6DAF0"
        android:layout_marginTop="52dp"/>

    <TextView
        android:id="@+id/tvQuote"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:text="Stay focused and never quit."
        android:textSize="15sp"
        android:textStyle="italic"
        android:gravity="center"
        android:textColor="#8F9BB3"
        android:layout_marginTop="18dp"/>

</LinearLayout>